NODE_ENV=development
PORT=5000
CLIENT_ORIGIN=http://localhost:5173
DATABASE_URL=postgres://postgres:postgres@localhost:5432/employee_performance
DB_CONNECTION_TIMEOUT_MS=10000
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=8h
# Master Dashboard SSO settings.
# Change SSO_SECRET here and in the Master Dashboard when rotating the shared secret.
SSO_SECRET=fjgroup-master-sso-shared-secret-2026-change-later
# This must exactly match the Master Dashboard JWT "app" value.
SSO_APP_NAME=employee-performance-dashboard
# Change this to map SSO to a different local CEO/admin login.
SSO_LOCAL_CEO_USERNAME=ceo@company.test
# Change this to redirect successful SSO users to a different frontend path.
SSO_REDIRECT_PATH=/sso-complete
